# Minimal kernel config for annotator on QEMU x86_64
# Base: buildroot qemu_x86_64_defconfig kernel config
# Changes: add V4L2/USB webcam, add i915/intel GPU, touch input,
#          remove sound, add ISO9660/CDROM, add DRM_I915

# Core
CONFIG_SYSVIPC=y
CONFIG_CGROUPS=y
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_SMP=y
CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y

# Essential virtual filesystems (required by almost everything)
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVPTS_FS=y
CONFIG_UNIX98_PTYS=y

# ACPI — required by Intel i915 (EDID, power, PCIe link training),
#         QEMU ACPI tables, and proper PCI device initialisation.
CONFIG_ACPI=y
CONFIG_ACPI_TABLE_UPGRADE=y
CONFIG_ACPI_SLEEP=y
CONFIG_ACPI_PROCESSOR=y
CONFIG_ACPI_PROCESSOR_IDLE=y
# ACPI video — display output power management / backlight on laptops
CONFIG_ACPI_VIDEO=y
CONFIG_PCI_MSI=y

# AGP — required by i915 on real hardware
CONFIG_AGP=y
CONFIG_AGP_INTEL=y

# VGA arbitration — i915 calls vga_client_register() during PCI probe;
# without this the driver deadlocks on real hardware (shows "_" then hangs)
CONFIG_VGA_ARB=y
CONFIG_VGA_ARB_MAX_GPUS=16
CONFIG_VGA_CONSOLE=y

# Intel IOMMU (VT-d) — on real hardware with VT-d enabled in firmware,
# i915 DMA goes through the IOMMU; without this support compiled in the
# GPU init hangs. DEFAULT_ON is NOT set so it's passive unless BIOS enables it.
CONFIG_IOMMU_SUPPORT=y
CONFIG_IOMMU_API=y
CONFIG_IOMMU_IOVA=y
CONFIG_IOMMU_DMA=y
CONFIG_DMAR_TABLE=y
CONFIG_INTEL_IOMMU=y
# CONFIG_INTEL_IOMMU_DEFAULT_ON is not set
CONFIG_INTEL_IOMMU_SCALABLE_MODE_DEFAULT_ON=y

# No network runtime (still compiled for DHCP at install if needed)
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
# CONFIG_INET is not set
# CONFIG_WIRELESS is not set

# Storage / boot
CONFIG_PCI=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_VIRTIO_BLK=y
CONFIG_BLK_DEV_SD=y
CONFIG_SCSI_VIRTIO=y
CONFIG_ATA=y
CONFIG_ATA_PIIX=y
CONFIG_SATA_AHCI=y
CONFIG_BLK_DEV_NVME=y

# Serial console (QEMU)
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_VIRTIO_CONSOLE=y

# VirtIO
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_VIRTIO_INPUT=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_MMIO_CMDLINE_DEVICES=y

# GPU: Intel i915 (real hardware) + virtio-gpu + VESA fallback
CONFIG_DRM=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_I915=y
CONFIG_DRM_VIRTIO_GPU=y
CONFIG_DRM_VIRTIO_GPU_KMS=y
CONFIG_DRM_BOCHS=y
# Remove QXL (not needed)
# CONFIG_DRM_QXL is not set
# fbdev emulation: lets Xorg vesa/fbdev driver use /dev/fb0 from a KMS driver
CONFIG_DRM_FBDEV_EMULATION=y

# Framebuffer console (needed for early boot / fallback)
CONFIG_FB=y
CONFIG_FB_VESA=y
CONFIG_FRAMEBUFFER_CONSOLE=y

# Input: keyboard, mouse, evdev (touch acts as mouse via evdev)
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MOUSE=y
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_MOUSE_PS2=y
CONFIG_MOUSE_PS2_VMMOUSE=y
# Multitouch
CONFIG_INPUT_MT_LIB=y

# USB (webcam / V4L2 capture devices + HID keyboard/mouse)
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_UHCI_HCD=y
CONFIG_USB_STORAGE=y
CONFIG_USB_VIDEO_CLASS=y
# USB HID — USB keyboards, mice, and touchscreens
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_USB_HID=y
CONFIG_HID_PID=y

# V4L2 (webcam capture)
CONFIG_MEDIA_SUPPORT=y
CONFIG_MEDIA_USB_SUPPORT=y
CONFIG_VIDEO_DEV=y
CONFIG_VIDEO_V4L2=y
CONFIG_VIDEO_UVC=y
CONFIG_VIDEOBUF2_CORE=y
CONFIG_VIDEOBUF2_VMALLOC=y

# I2C (needed by i915)
CONFIG_I2C=y
CONFIG_I2C_I801=y

# Intel CPU: microcode updates + idle driver (prevents boot hang on real hardware)
# Note: MICROCODE covers both Intel and AMD in kernel 6.6+ (MICROCODE_INTEL merged)
CONFIG_MICROCODE=y
CONFIG_INTEL_IDLE=y

# No sound
# CONFIG_SOUND is not set
# CONFIG_SND is not set

# EFI / UEFI stub support
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_VARS=y
# EFI handover protocol — proper GRUB→kernel EFI handover (required on some firmware)
CONFIG_EFI_HANDOVER_PROTOCOL=y
# EFI framebuffer — presents UEFI GOP as /dev/fb0 for fbdev X driver
CONFIG_FB_EFI=y

# ISO9660 / CDROM boot
CONFIG_ISO9660_FS=y
CONFIG_JOLIET=y
CONFIG_BLK_DEV_SR=y
CONFIG_ATA_GENERIC=y

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_AUTOFS4_FS=y

# Misc
CONFIG_HW_RANDOM_VIRTIO=m
CONFIG_UNWINDER_FRAME_POINTER=y

# eudev requirements — inotify for /sys monitoring, netlink for uevent
CONFIG_INOTIFY_USER=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EPOLL=y
